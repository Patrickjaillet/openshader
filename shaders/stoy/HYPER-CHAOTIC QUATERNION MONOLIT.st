// ==========================================================
// NAME : HYPER-CHAOTIC QUATERNION MONOLITH
// ==========================================================
// This shader renders a slice of a 4D Quaternion Julia Set.
// The "instability" is generated by modulating the 4D constant
// 'c' using a chaotic oscillation. The rendering engine uses
// a high-precision distance estimator for 4D-to-3D projection.
// The background is a multi-layered procedural nebula
// simulating cosmic dust.
// ==========================================================
// Credits : Patrick JAILLET
// https://shaderstudio.xo.je
// https://renderforge.ct.ws

#define ITERATIONS 8
#define MAX_STEPS 100
#define SURF_DIST 0.001

// Quaternion math: z = z^2 + c
vec4 qSq(vec4 q) {
    return vec4(
        q.x*q.x - q.y*q.y - q.z*q.z - q.w*q.w,
        2.0*q.x*q.y,
        2.0*q.x*q.z,
        2.0*q.x*q.w
    );
}

// Distance Estimator and Glow Collector
float GetDist(vec3 p, inout vec3 glow) {
    // Chaotic constant C
    vec4 c = vec4(
        -0.2 + 0.2*sin(iTime*0.3), 
        0.5 + 0.1*cos(iTime*0.4), 
        -0.3 + 0.1*sin(iTime*0.5), 
        0.15*cos(iTime*0.2)
    );
    
    vec4 z = vec4(p, 0.0);
    float md2 = 1.0;
    float mz2 = dot(z,z);

    for(int i=0; i<ITERATIONS; i++) {
        md2 *= 4.0 * mz2;
        z = qSq(z) + c;
        mz2 = dot(z,z);
        if(mz2 > 4.0) break;
    }
    
    float d = 0.25 * sqrt(mz2/md2) * log(mz2);
    
    // Bloom/Glow Accumulation
    vec3 bloomCol = 0.5 + 0.5*cos(iTime*0.5 + vec3(0,2,4) + p.y*0.5);
    glow += bloomCol * (0.015 / (0.01 + d*d)); 
    
    return d;
}

// Noise for the cosmic background
float noise(vec3 p) {
    return fract(sin(dot(p, vec3(12.9898, 78.233, 45.164))) * 43758.5453);
}

vec3 GetNebula(vec2 uv) {
    float n = 0.0;
    vec2 p = uv * 2.5;
    float amp = 0.5;
    for(int i=0; i<3; i++) {
        n += noise(vec3(p, iTime*0.02)) * amp;
        p *= 2.2; amp *= 0.5;
    }
    return mix(vec3(0.01, 0.005, 0.02), vec3(0.05, 0.02, 0.1), n);
}

vec3 GetNormal(vec3 p) {
    vec3 g; // dummy glow
    float d = GetDist(p, g);
    vec2 e = vec2(0.01, 0);
    vec3 n = d - vec3(
        GetDist(p - e.xyy, g),
        GetDist(p - e.yxy, g),
        GetDist(p - e.yyx, g));
    return normalize(n);
}

void mainImage( out vec4 fragColor, in vec2 fragCoord ) {
    vec2 uv = (fragCoord - 0.5 * iResolution.xy) / iResolution.y;
    
    vec3 ro = vec3(0, 0, -2.8);
    vec3 rd = normalize(vec3(uv, 1.5));
    
    vec3 col = vec3(0);
    vec3 glow = vec3(0);
    float d = 0.0;
    
    // Raymarching loop with glow accumulation
    for(int i=0; i<MAX_STEPS; i++) {
        vec3 p = ro + rd * d;
        float ds = GetDist(p, glow);
        d += ds * 0.8; // Safe stepping
        if(d > 10.0 || ds < SURF_DIST) break;
    }
    
    if(d < 10.0) {
        vec3 p = ro + rd*d;
        vec3 n = GetNormal(p);
        
        // Lighting
        float diff = dot(n, normalize(vec3(1,2,-3))) * 0.5 + 0.5;
        vec3 rainbow = 0.5 + 0.5*cos(iTime + p.xyy + vec3(0,2,4));
        
        col = rainbow * diff;
        
        // Soft Shadow/AO
        vec3 dummy;
        float occ = clamp(GetDist(p + n*0.1, dummy)*10.0, 0.0, 1.0);
        col *= occ;
    } else {
        col = GetNebula(uv);
    }
    
    // Add the accumulated bloom/glow
    col += glow * 0.12;
    
    // Tone mapping and gamma
    col = col / (1.0 + col); 
    col = pow(col, vec3(0.4545));
    
    fragColor = vec4(col, 1.0);
}