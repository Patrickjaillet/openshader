// TRANSITION: Wipe haut → bas
// Rideau vertical descendant avec bord adouci.
// iChannel0 = scène A, iChannel1 = scène B, iProgress = 0 → 1

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec2 uv = fragCoord / iResolution.xy;

    float edge   = 1.0 - iProgress;
    float feather = 0.015;
    float mask   = smoothstep(edge - feather, edge + feather, 1.0 - uv.y);

    vec4 a = texture(iChannel0, uv);
    vec4 b = texture(iChannel1, uv);
    fragColor = mix(a, b, mask);
}
